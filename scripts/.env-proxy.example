# Конфиг для scripts/proxy.sh
# Скопируй в scripts/.env-proxy и заполни своими данными.
# Файл .env-proxy в .gitignore — содержит IP/имя VPS, которые не стоит публиковать.

# IP или DNS-имя VPS, через который проксируем
PROXY_HOST=vps.example.com

# Пользователь на VPS (должен иметь SSH-доступ по ключу)
PROXY_USER=dazila

# SSH-порт VPS
PROXY_SSH_PORT=22

# Локальный порт для SOCKS5 (можно не трогать, если не занят)
SOCKS_PORT=1080

# Локальный порт для Privoxy (HTTP-прокси, в который преобразуется SOCKS5)
HTTP_PORT=8118
